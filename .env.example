# ┌──────────────────────────────────────────┐
# │         Beastie Bot — Environment Config     │
# └──────────────────────────────────────────┘

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Discord bot token
# Get from: https://discord.com/developers/applications → your app → TOKEN
DISCORD_TOKEN=your_bot_token_here

# Discord server ID (the ONLY server where the bot works)
# Right-click server name → Copy Server ID (enable Dev Mode first)
# Bot is exclusive to this server and won't work in other guilds
GUILD_ID=your_guild_id_here

# Discord app/client ID
# Get from: https://discord.com/developers/applications → your app → APPLICATION ID
CLIENT_ID=your_client_id_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Configuration file path (relative or absolute)
# This file contains trigger actions and custom settings using channel IDs
# See config.json.example for template
CONFIG_FILE=./config.json

# GitHub integration (comma-separated owner/repo pairs for polling)
# Example: torvalds/linux,nickvdyck/nvim-config
GITHUB_REPOS=

# GitHub Personal Access Token (required if GITHUB_REPOS is set)
# Get from: https://github.com/settings/tokens → New token
GITHUB_TOKEN=

# Snapshot storage directory
# Stores guild snapshots (channels, roles) for git-like version control
SNAPSHOT_DIR=./snapshots

# Maximum number of snapshots to keep
SNAPSHOT_MAX=20

# Welcome embed banner image URL (optional)
# Leave blank to skip image in welcome message
WELCOME_IMAGE_URL=

# Bot logging level (debug, info, warn, error)
LOG_LEVEL=info

# Channel ID where GitHub updates are posted
# Right-click channel → Copy Channel ID
GITHUB_FEED_CHANNEL=📡│github-feed

# Channel ID where member join/leave logs go
# Right-click channel → Copy Channel ID
JOIN_LOG_CHANNEL=📋│var-log-syslog

# ┌──────────────────────────────────────────┐
# │              HOW TO GET CREDENTIALS       │
# └──────────────────────────────────────────┘
#
# 1. DISCORD_TOKEN:
#    - Go to https://discord.com/developers/applications
#    - Click "New Application"
#    - Go to "Bot" → "Add Bot"
#    - Under TOKEN, click "Copy"
#    - Enable these intents: Guilds, Guild Members, Guild Messages, Message Content, Guild Message Reactions
#
# 2. GUILD_ID:
#    - In Discord, enable Developer Mode (Settings → App Settings → Advanced → Developer Mode)
#    - Right-click your server name → "Copy Server ID"
#    - This is the ONLY server where the bot will operate
#
# 3. CLIENT_ID:
#    - Go to https://discord.com/developers/applications → your app
#    - Copy the APPLICATION ID on the General Information tab
#
# 4. Channel IDs for config.json:
#    - In Discord with Developer Mode enabled
#    - Right-click any channel → "Copy Channel ID"
#    - Add these to config.json for each trigger
#
# 5. GITHUB_TOKEN (optional):
#    - Go to https://github.com/settings/tokens
#    - Click "Generate new token" → "Generate new token (classic)"
#    - Select scope: repo (full control of private repositories)
#    - Copy and paste here

